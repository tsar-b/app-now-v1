APPNOW_CONFIG=./appnow.config.json
APPNOW_OUTPUT_DIR=./data/exports

# Mongo-backed source API
MONGO_API_BASE_URL=http://localhost:5000
MONGO_API_TOKEN=

# Supabase target
SUPABASE_URL=https://your-project.supabase.co
