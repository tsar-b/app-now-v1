{
  "source": {
    "kind": "mongodb",
    "uriEnv": "MONGO_URI",
    "database": ""
  },
  "collections": [
    {
      "name": "users",
      "mongoCollection": "users",
      "supabaseTable": "users",
      "approval": {
        "mode": "all"
      },
      "requiredFields": ["id", "name"],
      "mapping": {
        "id": "_id",
        "legacy_user_id": "userId",
        "name": "name",
        "phone": "phone",
        "email": "email",
        "provider": "provider",
        "is_admin": "isAdmin",
        "created_at": "createdAt"
      }
    },
    {
      "name": "bookings",
      "mongoCollection": "bookings",
      "supabaseTable": "bookings",
      "approval": {
        "mode": "field",
        "field": "status",
        "values": ["approved", "confirmed", "확정", "완료"]
      },
      "requiredFields": ["id", "reservation_date", "reservation_time", "status"],
      "mapping": {
        "id": "_id",
        "legacy_user_id": "user",
        "name": "name",
        "reservation_date": "reservationDate",
        "reservation_time": "reservationTime",
        "status": "status",
        "total_price": "totalPrice",
        "created_at": "createdAt"
      }
    }
  ]
}
